def _run():
    try:
        _decoded = base64.b85decode(_encrypted_code)
        _decompressed = zlib.decompress(_decoded)
        _code = marshal.loads(_decompressed)
        exec(_code, {'__name__': '__main__', '__file__': __file__})
    except Exception as e:
        print(f"ERROR: Failed to run encrypted application: {e}")
        input("Press Enter to exit...")
        raise

if __name__ == "__main__":
    _run()
